rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to check email domain
    // Controlled by config/domainRestriction document: { enabled: true/false }
    // exists() を先に確認しないと、ドキュメント非存在時に get().data がエラーになる
    function isValidDomain() {
      return !exists(/databases/$(database)/documents/config/domainRestriction) ||
             get(/databases/$(database)/documents/config/domainRestriction).data.enabled != true ||
             request.auth.token.email.matches('.*@g\\.nagano-c\\.ed\\.jp$');
    }

    // Helper function to get user data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Helper function to check if user is admin or staff
    function isAdminOrStaff() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role in ['admin', 'staff'];
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             getUserData().role == 'admin';
    }

    // Users collection
    match /users/{userId} {
      // 許可されたフィールドのみ更新可能（roleは含まない - 権限昇格攻撃を防止）
      function isAllowedUserUpdate() {
        let allowedFields = ['realName', 'notificationsEnabled', 'theme', 'lastLoginDate'];
        let changedFields = request.resource.data.diff(resource.data).affectedKeys();
        return changedFields.hasOnly(allowedFields);
      }

      // Anyone with valid domain can read any user (for leaderboards)
      allow read: if isSignedIn() && isValidDomain();

      // Users can only create their own document
      allow create: if isSignedIn() && isValidDomain() && request.auth.uid == userId;

      // ユーザー自身: 許可されたフィールドのみ更新可能
      // 管理者のみ: 全フィールド更新可能（roleを含む）
      allow update: if isSignedIn() && isValidDomain() && (
        (request.auth.uid == userId && isAllowedUserUpdate()) ||
        isAdmin()
      );

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // Point history collection
    match /pointHistory/{historyId} {
      // Users can read their own point history; admin/staff can read all
      allow read: if isSignedIn() && isValidDomain() && (resource.data.userId == request.auth.uid || isAdminOrStaff());

      // Write is denied from client — Cloud Functions only
      allow write: if false;
    }

    // Classes collection
    match /classes/{classId} {
      // Anyone authenticated can read
      allow read: if isSignedIn() && isValidDomain();

      // Create is allowed for authenticated users (for auto-initialization)
      allow create: if isSignedIn() && isValidDomain();

      // Update/delete is only for admin/staff
      allow update, delete: if isAdminOrStaff();
    }

    // Surveys collection
    match /surveys/{surveyId} {
      // Anyone authenticated can read active surveys
      allow read: if isSignedIn() && isValidDomain();

      // Only admin/staff can create/update/delete surveys
      allow write: if isAdminOrStaff();
    }

    // Survey responses collection
    match /surveyResponses/{responseId} {
      // Users can read their own responses; admin/staff can read all
      allow read: if isSignedIn() && isValidDomain() && (resource.data.userId == request.auth.uid || isAdminOrStaff());

      // Write is denied from client — Cloud Functions only
      allow write: if false;
    }

    // News collection
    match /news/{newsId} {
      // Anyone authenticated can read
      allow read: if isSignedIn() && isValidDomain();

      // Only admin/staff can write
      allow write: if isAdminOrStaff();
    }

    // Config collection (read-only for domain restriction flag etc.)
    match /config/{configId} {
      allow read: if true; // must be readable by rules themselves (get() call)
      allow write: if isAdminOrStaff();
    }

    // Feedbacks collection
    match /feedbacks/{feedbackId} {
      allow create: if isSignedIn() && isValidDomain();
      allow read: if isAdminOrStaff();
      allow update, delete: if false;
    }

    // Gacha items collection
    match /gachaItems/{itemId} {
      allow read: if isSignedIn() && isValidDomain();
      allow write: if isAdminOrStaff();
    }

    // Gacha history collection
    match /gachaHistory/{historyId} {
      allow read: if isSignedIn() && isValidDomain() &&
        (resource.data.userId == request.auth.uid || isAdminOrStaff());
      allow write: if false;
    }

    // Ticket history collection
    match /ticketHistory/{historyId} {
      allow read: if isSignedIn() && isValidDomain() &&
        (resource.data.userId == request.auth.uid || isAdminOrStaff());
      allow write: if false;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Anyone authenticated can read
      allow read: if isSignedIn() && isValidDomain();

      // Admin/staff can write anything
      allow create, delete: if isAdminOrStaff();

      // For updates: admin/staff can update anything, regular users can only update readBy
      allow update: if isAdminOrStaff() || (
        isSignedIn() && isValidDomain() &&
        // Only readBy field is changed
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']) &&
        // User is adding their own UID
        request.resource.data.readBy.hasAll(resource.data.readBy) &&
        request.resource.data.readBy.size() == resource.data.readBy.size() + 1 &&
        request.auth.uid in request.resource.data.readBy
      );
    }

    // Tetris scores collection (ランキング用)
    match /tetrisScores/{scoreId} {
      // Anyone authenticated can read (for leaderboards)
      allow read: if isSignedIn() && isValidDomain();

      // Write is denied from client — Cloud Functions only
      allow write: if false;
    }

    // Tetris stats collection (日別統計)
    match /tetrisStats/{userId} {
      // Users can read their own stats; admin/staff can read all
      allow read: if isSignedIn() && isValidDomain() && (userId == request.auth.uid || isAdminOrStaff());

      // Write is denied from client — Cloud Functions only
      allow write: if false;
    }

    // Auth errors collection
    match /authErrors/{errorId} {
      // Write is denied from client — Cloud Functions only
      allow write: if false;

      // Admin/staff can read all errors
      allow read: if isAdminOrStaff();
    }

    // Admin logs collection (監査ログ)
    match /adminLogs/{logId} {
      // Write is denied from client — Cloud Functions only
      allow write: if false;

      // Only admins can read audit logs
      allow read: if isAdmin();
    }
  }
}
